        "### Approach 4: Tune with SpotOptim, Train, and Predict\n",
        "\n",
        "As an alternative to Optuna, we can utilize `spotoptim` for surrogate-model-based Bayesian optimization. To integrate `spotoptim`, we define a custom wrapper that overrides the `tune` method to leverage `spotoptim_search_forecaster`. "
      ],
      "id": "6c50252b"
    },
    {
      "cell_type": "code",
      "metadata": {
        "cache": false
      },
      "source": [
        "#| label: approach-4-spotoptim-tuning\n",
        "#| echo: true\n",
        "\n",
        "from spotforecast2.model_selection import spotoptim_search_forecaster\n",
        "from spotforecast2.manager.trainer_full import LAGS_CONSIDER\n",
        "from spotforecast2_safe.data.fetch_data import load_timeseries\n",
        "from spotforecast2_safe.preprocessing import LinearlyInterpolateTS\n",
        "\n",
        "# Define the SpotOptim search space (using dictionary format)\n",
        "search_space_spotoptim_lgbm = {\n",
        "    \"num_leaves\": (8, 256),\n",
        "    \"max_depth\": (3, 16),\n",
        "    \"learning_rate\": (0.0001, 0.1, \"log10\"),\n",
        "    \"n_estimators\": (10, 1000, \"log10\"),\n",
        "    \"bagging_fraction\": (0.5, 1.0),\n",
        "    \"feature_fraction\": (0.5, 1.0),\n",
        "    \"reg_alpha\": (0.01, 100.0),\n",
        "    \"reg_lambda\": (0.01, 100.0),\n",
        "    # \"lags\": [str(lag) for lag in LAGS_CONSIDER],\n",
        "    \"lags\": [\"[1, 2, 3, 11, 12, 22, 23, 24, 47, 48, 167, 168]\", \"48\", \"24\", \"[1, 2, 24, 48]\", \"[1, 2, 23, 24, 47, 48]\", \"[1, 2, 11, 12, 23, 24, 167, 168]\"],\n",
        "}\n",
        "\n",
        "class ForecasterRecursiveLGBMSpotoptim(ForecasterRecursiveLGBMFull):\n",
        "    def __init__(self, iteration: int, lags: int = 12, **kwargs):\n",
        "        super().__init__(iteration=iteration, lags=lags, **kwargs)\n",
        "\n",
        "    def tune(self) -> None:\n",
        "        logger.info(\"Tuning %s Forecaster %d with spotoptim\", self.name.upper(), self.iteration)\n",
        "        \n",
        "        y = load_timeseries()\n",
        "        y = LinearlyInterpolateTS().fit_transform(y)\n",
        "        X = self.preprocessor.build(start_date=y.index.min(), end_date=self.end_dev)\n",
        "\n",
        "        end_train = self.end_dev - pd.Timedelta(hours=self.predict_size * self.refit_size)\n",
        "        start_train = self._get_init_train(y.index.min(), end_train)\n",
        "        fixed_train_size = self.train_size is not None\n",
        "        length_training = len(y.loc[start_train:end_train])\n",
        "\n",
        "        results, optimizer = spotoptim_search_forecaster(\n",
        "            forecaster=self.forecaster,\n",
        "            y=y.loc[start_train : self.end_dev],\n",
        "            cv=self._build_cv(\n",
        "                train_size=length_training,\n",
        "                fixed_train_size=fixed_train_size,\n",
        "                refit=False,\n",
        "            ),\n",
        "            search_space=search_space_spotoptim_lgbm,\n",
        "            metric=self.metrics,\n",
        "            exog=X.loc[start_train : self.end_dev],\n",
        "            return_best=True,\n",
        "            random_state=self.random_state,\n",
        "            verbose=True,\n",
        "            # n_trials=self.n_trials,\n",
        "            n_trials=10,\n",
        "            n_initial=5,\n",
        "        )\n",
        "\n",
        "        results[\"name\"] = self.name\n",
        "        self.results_tuning = results\n",
        "        self.best_params = results.iloc[0].params\n",
        "        self.best_lags = results.iloc[0].lags\n",
        "\n",
        "        self.fit_with_best()\n",
        "        self.is_tuned = True\n",
        "\n",
        "        if self.save_model_to_file:\n",
        "            self.save_to_file()\n",
        "\n",
        "# Train and tune via handle_training using the new wrapper\n",
        "handle_training(\n",
        "    model_class=ForecasterRecursiveLGBMSpotoptim,\n",
        "    model_name=\"lgbm_tuned_spotoptim\",\n",
        "    force=True,\n",
        "    data_filename=config.data_filename,\n",
        "    end_dev=config.end_train_default\n",
        ")"
      ],
      "id": "approach-4-spotoptim-tuning",
